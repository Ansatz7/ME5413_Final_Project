<launch>

  <!-- ══════════════════════════════════════════════════════════════════
       full_mission.launch — 完整任务（一楼巡逻 + 箱子计数 + 二楼导航）
       前提：先启动 world.launch
       本文件包含：
         - 地图服务
         - Velodyne z轴点云过滤（0.2~2.0m）
         - hdl_localization 3D NDT 定位
         - move_base (TEB 局部规划器)
         - box_counter 箱子计数
         - level1_patrol 一楼巡逻状态机
         - auto_navigator 二楼导航状态机（等待 /me5413/level1_done）
  ═══════════════════════════════════════════════════════════════════ -->

  <!-- 地图服务 -->
  <arg name="map_file" default="$(find me5413_world)/maps/me5413_2d_map.yaml"/>
  <node name="map_server" pkg="map_server" type="map_server" args="$(arg map_file)"/>

  <!-- 点云 z 轴过滤（保留 0.2~2.0m，去掉地面和天花板噪声） -->
  <node pkg="nodelet" type="nodelet" name="pcl_manager"
        args="manager" output="screen"/>
  <node pkg="nodelet" type="nodelet" name="velodyne_z_filter"
        args="load pcl/PassThrough pcl_manager" output="screen">
    <remap from="~input"  to="/mid/points"/>
    <remap from="~output" to="/mid/points_filtered"/>
    <param name="filter_field_name" value="z"/>
    <param name="filter_limit_min"  value="0.2"/>
    <param name="filter_limit_max"  value="2.0"/>
  </node>

  <!-- 定位：hdl_localization（3D NDT） -->
  <include file="$(find hdl_localization)/launch/hdl_localization.launch"/>

  <!-- 自主导航：move_base（绑定 P 核 4-7） -->
  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen"
        launch-prefix="taskset -c 4,5,6,7">
    <rosparam file="$(find me5413_world)/config/costmap_common_params.yaml" command="load" ns="global_costmap"/>
    <rosparam file="$(find me5413_world)/config/costmap_common_params.yaml" command="load" ns="local_costmap"/>
    <rosparam file="$(find jackal_navigation)/params/map_nav_params/local_costmap_params.yaml"  command="load"/>
    <rosparam file="$(find jackal_navigation)/params/map_nav_params/global_costmap_params.yaml" command="load"/>
    <param name="global_costmap/origin_x"          value="-5.0"/>
    <param name="global_costmap/origin_y"          value="-8.0"/>
    <param name="global_costmap/width"             value="75.0"/>
    <param name="global_costmap/height"            value="35.0"/>
    <param name="global_costmap/update_frequency"  value="2.0"/>
    <param name="global_costmap/publish_frequency" value="1.0"/>
    <rosparam file="$(find jackal_navigation)/params/move_base_params.yaml" command="load"/>
    <param name="base_global_planner" value="navfn/NavfnROS"/>
    <param name="base_local_planner"  value="teb_local_planner/TebLocalPlannerROS"/>
    <rosparam file="$(find me5413_world)/config/teb_local_planner_params.yaml" command="load"/>
    <param name="controller_frequency" value="10.0"/>
    <rosparam param="TebLocalPlannerROS/footprint_model/type" subst_value="true">polygon</rosparam>
    <rosparam param="TebLocalPlannerROS/footprint_model/vertices">
      [[-0.21, -0.165], [-0.21, 0.165], [0.21, 0.165], [0.21, -0.165]]
    </rosparam>
    <remap from="odom" to="odometry/filtered"/>
  </node>

  <!-- 箱子计数节点（绑定 P 核 8-11，YOLO 走 GPU） -->
  <node name="box_counter_node" pkg="me5413_world" type="box_counter.py" output="screen"
        launch-prefix="taskset -c 8,9,10,11">
    <param name="use_ground_truth"  value="false"/>
    <param name="map_frame"         value="map"/>
    <param name="robot_frame"       value="base_link"/>
    <param name="continuous_hz"     value="2.0"/>
    <param name="move_dist_min"     value="0.3"/>
    <param name="min_obs"           value="2"/>
    <param name="min_obs_dist"      value="0.5"/>
    <param name="min_conf"          value="0.9"/>
    <param name="dedup_same_digit"  value="1.2"/>
    <param name="dedup_any_digit"   value="0.4"/>
    <param name="min_bbox_pts"      value="1"/>
    <param name="save_debug"        value="false"/>
    <param name="show_gt"           value="true"/>
  </node>

  <!-- 一楼巡逻状态机 -->
  <node name="level1_patrol" pkg="me5413_world" type="level1_patrol.py" output="screen"/>

  <!-- 二楼导航状态机（等待 /me5413/level1_done 后启动） -->
  <node name="auto_navigator" pkg="me5413_world" type="auto_navigator.py" output="screen"/>

  <!-- RViz -->
  <node type="rviz" name="rviz" pkg="rviz"
        args="-d $(find me5413_world)/rviz/hdl_locolization.rviz"
        output="log" respawn="false"/>

</launch>
