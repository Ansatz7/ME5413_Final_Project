<launch>

  <!-- Keyboard teleop -->
  <node name="teleop_twist_keyboard" pkg="teleop_twist_keyboard" type="teleop_twist_keyboard.py" output="screen" respawn="true"/>

  <!-- YOLO live detection -->
  <node name="yolo_live_test" pkg="me5413_world" type="yolo_live_test.py" output="screen"/>

  <!-- RViz (same config as manual, add Image display for /me5413/yolo_live manually) -->
  <node type="rviz" name="rviz" pkg="rviz" args="-d $(find me5413_world)/rviz/manual.rviz" output="log" respawn="false"/>

</launch>
